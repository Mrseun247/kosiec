# ════════════════════════════════════════════════════════════
# KOSIEC Backend — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit your actual .env file — it is already gitignored.
# ════════════════════════════════════════════════════════════

PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── MongoDB Atlas ───────────────────────────────────────────
# Get this from Atlas → Database → Connect → Drivers.
# Replace <db_password> with your actual database user password
# (the one you set when creating the DB user in Atlas, NOT your Atlas login).
# If your password contains special characters (@ : / ? # etc.),
# URL-encode them, e.g. "@" becomes "%40".
MONGODB_URI=MONGODB_URI=mongodb+srv://mrseun007_db_user:tolulope@cluster0.q93balm.mongodb.net/kosiec?appName=Cluster0
# ── JWT ─────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_string_at_least_32_characters
JWT_EXPIRE=7d

# ── Cloudinary (cloud file storage for photos & documents) ──
# Get this from Cloudinary Dashboard → API Environment Variable.
# Format: cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=cloudinary://777212413124137:GqtBDJ4Y9CCfDt1zr_PUHjjoJDs@dcjveb2al

# ── Uploads ─────────────────────────────────────────────────
MAX_FILE_SIZE=5242880

# ── Email (Nodemailer — for contact form notifications) ─────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=erimamman2@gmail.com
EMAIL_PASS=your_gmail_app_password_here
ADMIN_EMAIL=erimamman2@gmail.com
